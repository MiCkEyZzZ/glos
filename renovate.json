{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 10,
  "labels": ["dependencies"],
  "lockFileMaintenance": {
    "enabled": true,
    "recreateWhen": "always",
    "branchTopic": "cargo-lock-update",
    "commitMessageAction": "Update Cargo.lock"
  },
  "packageRules": [
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "description": "Автомерж патч-обновлений Rust зависимостей"
    },
    {
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["minor", "major"],
      "automerge": false,
      "description": "Минорные и мажорные обновления требуют ревью"
    },
    {
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "description": "Автомерж патч-обновлений GitHub Actions"
    }
  ],
  "schedule": ["every weekend"],
  "ignoreDeps": []
}
